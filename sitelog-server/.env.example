MONGO_URI=mongodb://127.0.0.1:27017/sitelog
JWT_SECRET=change-this-to-a-long-random-string-min-32-chars
JWT_REFRESH_SECRET=change-this-to-another-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173
PORT=5000
NODE_ENV=development

# Set USE_MEMORY_DB=true if MongoDB is not installed locally
USE_MEMORY_DB=false
